# Copy to `.env` in the project root and adjust values.
# Requires `python-dotenv` (see README). Do not commit `.env` with secrets.
#
# cp .env.example .env

# Python logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Verbose LangGraph execution (node transitions on stderr).
# Use: 1, true, or yes to enable. Any other value disables.
AGENT_GRAPH_DEBUG=0

# Ollama HTTP API (default if unset: http://127.0.0.1:11434)
# OLLAMA_HOST=http://127.0.0.1:11434

# Skip checking that LLM / embedding / vision models exist locally (tests only; not recommended for normal use).
# SKIP_OLLAMA_CHECK=0
